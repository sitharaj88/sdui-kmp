<?xml version="1.0" encoding="utf-8"?>
<!--
  Local-development only. Android 9+ (API 28) blocks cleartext HTTP by default. The sample talks
  to a sample-server running on the developer's machine over plain HTTP, so cleartext is permitted
  ONLY for the loopback / emulator-host addresses used in that flow:
    - 10.0.2.2  : the Android emulator's alias for the host machine's localhost
    - 127.0.0.1 / localhost : the device's loopback, tunnelled to the host by `adb reverse tcp:8080 tcp:8080`
  Every other destination still requires HTTPS. Production apps must not ship a cleartext allowance.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
